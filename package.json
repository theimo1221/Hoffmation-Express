{
  "name": "hoffmation-express",
  "description": "Example for own Hoffmation projects",
  "version": "0.0.1",
  "files": [
    "lib/**/*"
  ],
  "main": "lib/src/index.js",
  "types": "lib/src/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theimo1221/Hoffmation-Express.git"
  },
  "author": "Thiemo Hoffmann",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/theimo1221/Hoffmation-Express/issues"
  },
  "homepage": "https://github.com/theimo1221/Hoffmation-Express#readme",
  "scripts": {
    "bun-config-test": "bun ts-node RoomCreation/createRooms.ts && bun run lint-fix-rooms && bun run build",
    "bun-create-rooms": "bun run create-rooms",
    "bun-start": "bun run start",
    "lint-fix-all": "eslint ./src/{*.ts,*.js} --fix --no-error-on-unmatched-pattern",
    "lint-fix-rooms": "eslint ./src/OwnRooms/**/{*.ts,*.js} --fix --no-error-on-unmatched-pattern",
    "lint-fix-createRooms": "eslint ./RoomCreation/{*.ts,*.js} --fix --no-error-on-unmatched-pattern",
    "build:express": "tsc --build --clean",
    "build:webui": "cd webui && npm ci && npm run build",
    "build": "npm run build:webui && npm run build:express",
    "start": "tsx src/index.ts --no-cache",
    "pg-test": "tsc && node lib/src/tests/pg-test.js",
    "config-test": "tsx src/tests/config-test.ts --no-cache",
    "create-rooms": "ts-node RoomCreation/createRooms.ts && npm run lint-fix-rooms && npm run build",
    "check-package-upgrades": "npx npm-check-updates -i",
    "test": "vitest run && playwright test",
    "test:backend": "vitest run",
    "test:backend:watch": "vitest run --watch",
    "dev:mock": "tsx test/dev-server.ts --no-cache",
    "dev:mock:watch": "concurrently -k -n api,ui -c blue,magenta \"tsx watch test/dev-server.ts\" \"cd webui && npx vite build --watch\"",
    "dev:proxy": "cd webui && npx vite",
    "dev:proxy:watch": "concurrently -k -n api,ui -c blue,magenta \"tsx watch test/dev-server.ts\" \"cd webui && HOFFMATION_API_PROXY_TARGET=http://localhost:3000 npx vite\"",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "coverage:backend": "vitest run --coverage",
    "coverage:ui": "npm run test:ui",
    "coverage": "npm run coverage:backend && npm run coverage:ui && lcov-result-merger \"coverage/*/lcov.info\" coverage/lcov.info"
  },
  "dependencies": {
    "@types/cookie-parser": "^1.4.10",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "5.2.1",
    "hoffmation-base": "3.4.7",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@alcalzone/pak": "0.12.0",
    "@iobroker/types": "^7.1.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.2.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "5.2.1",
    "eslint-plugin-unused-imports": "^3.2.0",
    "postcss": "^8.4.41",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "concurrently": "^9.1.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "@playwright/test": "^1.48.0",
    "monocart-coverage-reports": "^2.11.0",
    "lcov-result-merger": "^5.0.1",
    "typescript": "^5.9.3"
  }
}
